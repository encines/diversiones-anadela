            <div class="flex justify-center" data-animate data-delay="200">
              <div class="bg-white rounded-custom-lg p-8 max-w-[400px] w-full text-gray-800 shadow-[0_20px_50px_rgba(0,0,0,0.2)]">
                <h3 class="text-[1.25rem] font-extrabold mb-4">Datos del negocio</h3>
