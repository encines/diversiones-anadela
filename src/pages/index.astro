    <Footer />

    <script>
      const faqItems = document.querySelectorAll<HTMLDetailsElement>('[data-faq] details');
      faqItems.forEach((item) => {
        item.addEventListener('toggle', () => {
          if (!item.open) return;
          faqItems.forEach((other) => {
            if (other !== item) other.open = false;
          });
        });
      });



      const observer = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            const target = entry.target as HTMLElement;
            const delay = target.dataset.delay || '0';
            setTimeout(() => {
              target.classList.add('visible');
            }, parseInt(delay));
            observer.unobserve(target);
          }
        });
      }, { threshold: 0.1, rootMargin: '0px 0px -40px 0px' });

      document.querySelectorAll('[data-animate]').forEach((el) => observer.observe(el));

      // Gallery Carousel Controller
      const slidesContainer = document.getElementById('carouselSlides');
      const prevButton = document.getElementById('carouselPrev');
      const nextButton = document.getElementById('carouselNext');
      const dots = document.querySelectorAll('.carousel-dot');
      const thumbs = document.querySelectorAll<HTMLElement>('.carousel-thumb');
      const slideCount = 7;
      let currentSlide = 0;
      let autoplayInterval: number | undefined;

      function updateCarousel() {
        if (!slidesContainer) return;
        slidesContainer.style.transform = `translateX(-${currentSlide * 100}%)`;

        // Update indicators (dots)
        dots.forEach((dot, idx) => {
          if (idx === currentSlide) {
            dot.classList.add('bg-yellow-500', 'w-5');
            dot.classList.remove('bg-white/40');
          } else {
            dot.classList.remove('bg-yellow-500', 'w-5');
            dot.classList.add('bg-white/40');
          }
        });

        // Update thumbnails
        thumbs.forEach((thumb, idx) => {
          if (idx === currentSlide) {
            thumb.classList.add('border-yellow-500', 'opacity-100', 'scale-105', 'shadow-lg');
            thumb.classList.remove('opacity-60', 'border-transparent');
            
            // Scroll thumbnail horizontally into view inside its container,
            // without shifting the main page vertically.
            const thumbnailContainer = document.getElementById('carouselThumbnails');
            if (thumbnailContainer) {
              const containerWidth = thumbnailContainer.clientWidth;
              const thumbOffsetLeft = thumb.offsetLeft;
              const thumbWidth = thumb.clientWidth;
              thumbnailContainer.scrollTo({
                left: thumbOffsetLeft - (containerWidth / 2) + (thumbWidth / 2),
                behavior: 'smooth'
              });
            }
          } else {
            thumb.classList.remove('border-yellow-500', 'opacity-100', 'scale-105', 'shadow-lg');
            thumb.classList.add('opacity-60', 'border-transparent');
          }
        });
      }

      function nextSlide() {
        currentSlide = (currentSlide + 1) % slideCount;
        updateCarousel();
      }

      function prevSlide() {
        currentSlide = (currentSlide - 1 + slideCount) % slideCount;
        updateCarousel();
      }

      if (nextButton && prevButton) {
        nextButton.addEventListener('click', () => {
          nextSlide();
          resetAutoplay();
        });
        prevButton.addEventListener('click', () => {
          prevSlide();
          resetAutoplay();
        });
      }

      dots.forEach(dot => {
        dot.addEventListener('click', () => {
          currentSlide = parseInt(dot.getAttribute('data-index') || '0');
          updateCarousel();
          resetAutoplay();
        });
      });

      thumbs.forEach(thumb => {
        thumb.addEventListener('click', () => {
          currentSlide = parseInt(thumb.getAttribute('data-index') || '0');
          updateCarousel();
          resetAutoplay();
        });
      });

      // Swipe support for touch screens
      let touchStartX = 0;
      let touchEndX = 0;

      if (slidesContainer) {
        slidesContainer.addEventListener('touchstart', (e) => {
          const touchEvent = e as TouchEvent;
          touchStartX = touchEvent.changedTouches[0].screenX;
        }, { passive: true });

        slidesContainer.addEventListener('touchend', (e) => {
          const touchEvent = e as TouchEvent;
          touchEndX = touchEvent.changedTouches[0].screenX;
          handleSwipe();
        }, { passive: true });
      }

      function handleSwipe() {
        const swipeThreshold = 50;
        if (touchStartX - touchEndX > swipeThreshold) {
          nextSlide();
          resetAutoplay();
        } else if (touchEndX - touchStartX > swipeThreshold) {
          prevSlide();
          resetAutoplay();
        }
      }

      function startAutoplay() {
        autoplayInterval = setInterval(nextSlide, 5000) as unknown as number;
      }

      function resetAutoplay() {
        clearInterval(autoplayInterval);
        startAutoplay();
      }

      // Initialize
      updateCarousel();
      startAutoplay();
    </script>
  </body>
</html>
