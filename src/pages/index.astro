                <a class="inline-flex items-center justify-center gap-2 font-bold font-sans rounded-full cursor-pointer transition-all duration-300 ease-[cubic-bezier(0.4,0,0.2,1)] whitespace-nowrap hover:-translate-y-0.5 active:translate-y-0 h-12 px-6 w-full bg-gradient-to-br from-yellow-400 to-yellow-500 text-gray-900 shadow-[0_4px_14px_rgba(255,208,47,0.35)] hover:shadow-[0_8px_24px_rgba(255,208,47,0.45)]" href={whatsappUrl} target="_blank" rel="noreferrer">Mandar mensaje</a>
