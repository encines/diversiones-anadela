    title: 'Castillo Princesas con Arcos',
    category: 'brincolines',
    image: '/brincolines/princesasArcos.webp',
    desc: 'Un palacio de ensueño para las pequeñas de la casa. Diseño elegante con arcos reales e inflado impecable.',
    dimensions: '5m x 4m',
    badge: 'Fantasía'
  },
  {
    id: 'princesas-resbaladilla',
    title: 'Castillo Princesas con Resbaladilla',
    category: 'brincolines',
    image: '/brincolines/princesasResbaladilla.webp',
