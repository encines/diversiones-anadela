---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const businessName = 'Diversiones Anadela';
const phone = '6671198730';

const products = [
  {
    id: 'spiderman',
    title: 'Brincolín Spiderman',
    category: 'brincolines',
    image: '/brincolines/spiderman.webp',
    desc: 'El favorito de los pequeños superhéroes. Cuenta con zona de salto amplia y postes temáticos en 3D.',
    dimensions: '8m x 5m',
    badge: 'Popular'
  },
  {
    id: 'avengers',
    title: 'Castillo Avengers',
    category: 'brincolines',
    image: '/brincolines/avengers.webp',
    desc: 'Únete a los héroes más poderosos del planeta. Gran colorido, diseño de torre y seguridad reforzada.',
    dimensions: '9m x 4m',
    badge: 'El mas grande'
  },
  {
    id: 'escaladora-grande',
    title: 'Brincolín Escaladora Grande',
    category: 'brincolines',
    image: '/brincolines/escaladoraGrande.webp',
    desc: 'Diversión al máximo con escaladora vertical y una emocionante resbaladilla integrada de gran altura.',
    dimensions: '7m x 4m',
    badge: 'Escaladora grande'
  },

  {
    id: 'h2o-double',
    title: 'Acuático H2O Palmeras',
    category: 'acuaticos',
    image: '/brincolines/h2o2.webp',
    desc: 'Diseño tropical con palmeras inflables y deslizador acuático súper refrescante.',
    dimensions: '10m x 6m',
    badge: 'Acuático'
  },
  {
    id: 'miki',
    title: 'Castillo Mickey Mouse',
    category: 'brincolines',
    image: '/brincolines/mikiViejo.webp',
    desc: 'Un clásico que nunca falla. Con el diseño del ratón favorito de todos y zona de salto segura.',
    dimensions: '5m x 4m',
    badge: 'Clásico'
  },
  {
    id: 'palmeras',
    title: 'Brincolín Palmeras',
    category: 'brincolines',
    image: '/brincolines/palmeras.webp',
    desc: 'Lleva el ambiente de playa a tu evento. Colores vibrantes y gran espacio interior de rebote.',
    dimensions: '9m x 5m',
    badge: 'Grande'
  },
  {
    id: 'paw-patrol',
    title: 'Brincolín Paw Patrol',
    category: 'brincolines',
    image: '/brincolines/pawPatrol.webp',
    desc: 'Acompaña a Chase, Marshall y Skye en una aventura de saltos sin parar y postes de juego.',
    dimensions: '6m x 6m',
