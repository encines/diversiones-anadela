---
const { isHome = false } = Astro.props;

const businessName = 'Diversiones Anadela';
const phone = '6671198730';
const whatsappUrl = `https://wa.me/52${phone}?text=${encodeURIComponent('Hola, me interesa cotizar un brincolín/mobiliario para mi evento.')}`;
const homePrefix = isHome ? '' : '/';
---

<nav
  class={`fixed top-0 left-0 right-0 z-[10000] py-3 transition-all duration-300 ease-[cubic-bezier(0.4,0,0.2,1)] [&.scrolled]:bg-white/92 [&.scrolled]:backdrop-blur-md [&.scrolled]:shadow-sm [&.scrolled]:py-2 ${isHome ? 'bg-transparent text-white border-transparent' : 'bg-white/92 backdrop-blur-md shadow-sm scrolled py-2'}`}
  id="navbar"
  aria-label="Navegación principal"
>
  <div class="relative z-[10000] mx-auto flex w-full max-w-[1160px] items-center justify-between gap-4 px-4">
    <a
      href="/"
      class={`flex items-center gap-2 font-poppins font-extrabold text-lg transition-colors duration-300 ${isHome ? 'text-white [.scrolled_&]:text-gray-900' : 'text-gray-900'}`}
    >
      <img class="h-auto w-20" src="/logo_vacio.png" alt="Logo" />
    </a>

    <div class="hidden items-center gap-6 min-[980px]:flex">
      <a
        href={`${homePrefix}`}
        class={`text-sm font-medium transition-colors duration-300 ${isHome ? 'text-white/85 hover:text-white [.scrolled_&]:text-gray-600 [.scrolled_&]:hover:text-blue-900' : 'text-gray-600 hover:text-blue-900'}`}
        >Inicio</a
      >
      <a
        href={`${homePrefix}#servicios`}
        class={`text-sm font-medium transition-colors duration-300 ${isHome ? 'text-white/85 hover:text-white [.scrolled_&]:text-gray-600 [.scrolled_&]:hover:text-blue-900' : 'text-gray-600 hover:text-blue-900'}`}
        >Servicios</a
      >
      <a
        href="/catalog"
        class={`text-sm font-bold transition-colors duration-300 ${isHome ? 'text-yellow-400 hover:text-white [.scrolled_&]:text-blue-900 [.scrolled_&]:hover:text-blue-955' : 'text-blue-900 hover:text-blue-950'}`}
        >Catálogo</a
      >
      <a
        href={`${homePrefix}#galeria`}
        class={`text-sm font-medium transition-colors duration-300 ${isHome ? 'text-white/85 hover:text-white [.scrolled_&]:text-gray-600 [.scrolled_&]:hover:text-blue-900' : 'text-gray-600 hover:text-blue-900'}`}
        >Galería</a
      >
      <!-- <a href={`${homePrefix}#testimonios`} class={`text-sm font-medium transition-colors duration-300 ${isHome ? 'text-white/85 hover:text-white [.scrolled_&]:text-gray-600 [.scrolled_&]:hover:text-blue-900' : 'text-gray-600 hover:text-blue-900'}`}>Opiniones</a> -->
      <a
        href={`${homePrefix}#faq`}
        class={`text-sm font-medium transition-colors duration-300 ${isHome ? 'text-white/85 hover:text-white [.scrolled_&]:text-gray-600 [.scrolled_&]:hover:text-blue-900' : 'text-gray-600 hover:text-blue-900'}`}
        >Preguntas</a
      >
      <a
        href={`${homePrefix}#contacto`}
        class={`text-sm font-medium transition-colors duration-300 ${isHome ? 'text-white/85 hover:text-white [.scrolled_&]:text-gray-600 [.scrolled_&]:hover:text-blue-900' : 'text-gray-600 hover:text-blue-900'}`}
        >Contacto</a
      >
    </div>

    <a
      class={`inline-flex items-center justify-center gap-2 font-bold font-sans rounded-full cursor-pointer transition-all duration-300 ease-[cubic-bezier(0.4,0,0.2,1)] whitespace-nowrap hover:-translate-y-0.5 active:translate-y-0 h-[38px] px-[1.1rem] text-[0.85rem] border hover:bg-white/10 hover:border-white/50 max-[979px]:hidden ${isHome ? 'bg-white/15 text-white border-white/25 [.scrolled_&]:bg-blue-900 [.scrolled_&]:text-white [.scrolled_&]:border-blue-900' : 'bg-blue-900 text-white border-blue-900'}`}
      href={whatsappUrl}
      target="_blank"
      rel="noreferrer"
    >
      Cotizar
    </a>

    <button
      class="flex cursor-pointer flex-col gap-[5px] border-none bg-none p-2 min-[980px]:hidden"
      id="navToggle"
      aria-label="Abrir menú"
      aria-expanded="false"
    >
      <span
        class={`block w-6 h-[2px] rounded-[2px] transition-all duration-300 ${isHome ? 'bg-white [.scrolled_&]:bg-gray-800' : 'bg-gray-800'}`}
      ></span>
      <span
        class={`block w-6 h-[2px] rounded-[2px] transition-all duration-300 ${isHome ? 'bg-white [.scrolled_&]:bg-gray-800' : 'bg-gray-800'}`}
      ></span>
      <span
        class={`block w-6 h-[2px] rounded-[2px] transition-all duration-300 ${isHome ? 'bg-white [.scrolled_&]:bg-gray-800' : 'bg-gray-800'}`}
      ></span>
    </button>
  </div>
</nav>

<!-- Mobile Drawer -->
<div
  class="pointer-events-none fixed inset-0 z-[999] flex flex-col gap-1 bg-white px-8 pt-24 pb-8 opacity-0 transition-opacity duration-300 min-[980px]:hidden"
  id="navMobile"
>
  <a
    href={`${homePrefix}#servicios`}
    class="block border-b border-gray-100 py-4 text-xl font-semibold text-gray-800">Servicios</a
  >
  <a
    href="/catalog"
    class="block flex items-center justify-between border-b border-gray-100 py-4 text-xl font-bold text-blue-900"
    >Catálogo <span
      class="rounded-full bg-yellow-400 px-2.5 py-1 text-[0.7rem] font-black tracking-wider text-gray-900 uppercase"
      >Nuevo</span
    ></a
  >
  <a
    href={`${homePrefix}#galeria`}
    class="block border-b border-gray-100 py-4 text-xl font-semibold text-gray-800">Galería</a
  >
  <a
    href={`${homePrefix}#testimonios`}
    class="block border-b border-gray-100 py-4 text-xl font-semibold text-gray-800">Opiniones</a
  >
  <a
    href={`${homePrefix}#faq`}
    class="block border-b border-gray-100 py-4 text-xl font-semibold text-gray-800">Preguntas</a
  >
  <a
    href={`${homePrefix}#contacto`}
    class="block border-b border-gray-100 py-4 text-xl font-semibold text-gray-800">Contacto</a
  >
  <a
    class="mt-4 inline-flex h-12 w-full cursor-pointer items-center justify-center gap-2 rounded-full bg-gradient-to-br from-yellow-400 to-yellow-500 px-6 font-sans font-bold whitespace-nowrap text-gray-900 shadow-[0_4px_14px_rgba(255,208,47,0.35)] transition-all duration-300 ease-[cubic-bezier(0.4,0,0.2,1)] hover:-translate-y-0.5 hover:shadow-[0_8px_24px_rgba(255,208,47,0.45)] active:translate-y-0"
    href={whatsappUrl}
    target="_blank"
    rel="noreferrer">Cotiza por WhatsApp</a
  >
</div>

<style>
  /* Morph hamburger lines to close 'X' when menu is open */
  #navToggle.open span:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
  }
  #navToggle.open span:nth-child(2) {
    opacity: 0;
  }
  #navToggle.open span:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
  }

  /* Switch burger lines to dark when menu is open for high contrast on white bg */
  #navToggle.open span {
    background-color: #1f2937 !important;
  }

  /* Robust backup to toggle the mobile menu overlay visibility */
  #navMobile.open {
    opacity: 1 !important;
    pointer-events: auto !important;
    z-index: 9999 !important;
  }
</style>

<script is:inline>
  (function() {
    function initMenu() {
      const navToggle = document.getElementById('navToggle');
      const navMobile = document.getElementById('navMobile');
      
      if (navToggle && navMobile) {
        // Prevent duplicate listener registration
        if (navToggle.dataset.bound) return;
        navToggle.dataset.bound = "true";

        navToggle.addEventListener('click', () => {
          const isOpen = navMobile.classList.toggle('open');
          navToggle.classList.toggle('open');
          navToggle.setAttribute('aria-expanded', isOpen ? 'true' : 'false');
          
          if (isOpen) {
            navMobile.style.opacity = '1';
            navMobile.style.pointerEvents = 'auto';
          } else {
            navMobile.style.opacity = '0';
            navMobile.style.pointerEvents = 'none';
          }
        });

        navMobile.querySelectorAll('a').forEach((link) => {
          link.addEventListener('click', () => {
            navMobile.classList.remove('open');
            navToggle.classList.remove('open');
            navToggle.setAttribute('aria-expanded', 'false');
            navMobile.style.opacity = '0';
            navMobile.style.pointerEvents = 'none';
          });
        });
      }

      // Scroll color switching listener
      const navbar = document.getElementById('navbar');
      if (navbar && navbar.classList.contains('bg-transparent')) {
        window.addEventListener('scroll', () => {
          if (window.scrollY > 60) {
            navbar.classList.add('scrolled');
          } else {
            navbar.classList.remove('scrolled');
          }
        });
      }
    }

    // Initialize immediately AND on DOM content loaded to be 100% bulletproof
    initMenu();
    document.addEventListener('DOMContentLoaded', initMenu);
    window.addEventListener('load', initMenu);
  })();
</script>
